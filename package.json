{
  "name": "practice-software-testing-playwright",
  "version": "1.0.0",
  "description": "A portfolio-grade Playwright UI and API test framework for Practice Software Testing.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "playwright test",
    "test:ui": "playwright test --project=chromium",
    "test:api": "playwright test --project=api",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression --grep-invert @checkout",
    "test:checkout": "playwright test --project=chromium --grep @checkout",
    "test:list": "playwright test --list",
    "testomat:import": "check-tests playwright \"tests/**/*.spec.ts\" --typescript"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OleksandrMoldovan/yet-js-automation.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/OleksandrMoldovan/yet-js-automation/issues"
  },
  "homepage": "https://github.com/OleksandrMoldovan/yet-js-automation#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@testomatio/reporter": "^2.6.0",
    "@types/node": "^24.10.1",
    "check-tests": "^0.15.1",
    "eslint": "^9.39.2",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-playwright": "^2.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}
